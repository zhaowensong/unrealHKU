{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telecomtwin.local/schema/signal-frame-1.0.json",
  "title": "TelecomTwin Signal Simulation Frame",
  "type": "object",
  "required": ["schemaVersion", "frameId", "transmitters", "segments", "metrics"],
  "properties": {
    "schemaVersion": {"const": "telecom-twin.signal-frame/1.0"},
    "frameId": {"type": "string", "minLength": 1},
    "generatedAtUtc": {"type": "string", "format": "date-time"},
    "transmitters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "position", "frequencyMHz", "transmitPowerDbm"],
        "properties": {
          "id": {"type": "string"},
          "position": {"$ref": "#/$defs/vector"},
          "frequencyMHz": {"type": "number", "exclusiveMinimum": 0},
          "transmitPowerDbm": {"type": "number"}
        }
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start", "end", "receivedPowerDbm", "normalizedStrength", "bounceIndex", "sourceId", "bReflectionHit"],
        "properties": {
          "start": {"$ref": "#/$defs/vector"},
          "end": {"$ref": "#/$defs/vector"},
          "receivedPowerDbm": {"type": "number"},
          "normalizedStrength": {"type": "number", "minimum": 0, "maximum": 1},
          "bounceIndex": {"type": "integer", "minimum": 0},
          "sourceId": {"type": "string"},
          "bReflectionHit": {"type": "boolean"},
          "hitProxyId": {"type": ["string", "null"]}
        }
      }
    },
    "metrics": {"type": "object"}
  },
  "$defs": {
    "vector": {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": {
        "x": {"type": "number"},
        "y": {"type": "number"},
        "z": {"type": "number"}
      },
      "additionalProperties": false
    }
  }
}
